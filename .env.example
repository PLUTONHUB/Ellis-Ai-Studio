# Configure these as deployment secrets; never commit real values.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.example/dashboard/google-business-callback
GBP_OAUTH_STATE_SECRET=
GBP_TOKEN_ENCRYPTION_KEY=
GBP_DASHBOARD_ACCESS_TOKEN=
# Optional: defaults to .data/google-business-tokens.json on Bun/Node deployments.
GBP_TOKEN_STORE_PATH=
