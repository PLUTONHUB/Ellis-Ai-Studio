# Configure these as deployment secrets; never commit real values.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.example/dashboard/google-business-callback
GBP_OAUTH_STATE_SECRET=
GBP_TOKEN_ENCRYPTION_KEY=
GBP_DASHBOARD_ACCESS_TOKEN=
# Optional: defaults to .data/google-business-tokens.json on Bun/Node deployments.
GBP_TOKEN_STORE_PATH=

# Meta publishing integration. Configure these as deployment secrets; never commit real values.
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=https://your-domain.example/dashboard/meta-callback
META_OAUTH_STATE_SECRET=
META_TOKEN_ENCRYPTION_KEY=
META_DASHBOARD_ACCESS_TOKEN=
# Optional: defaults to .data/meta-publishing.json on Bun/Node deployments.
META_TOKEN_STORE_PATH=
# Optional: defaults to v24.0. Pin this to the Graph API version approved for your app.
META_GRAPH_API_VERSION=v24.0
# Required only for AI caption generation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# A long-lived token authorized for the connected Instagram Business account.
INSTAGRAM_ACCESS_TOKEN=
