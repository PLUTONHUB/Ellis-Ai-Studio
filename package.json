{
  "name": "ellis-ai-studio",
  "private": true,
  "sideEffects": false,
  "version": "1.1.0",
  "type": "module",
  "description": "Ellis AI Studio service business website.",
  "scripts": {
    "dev": "vite dev --force",
    "setup:https": "powershell -ExecutionPolicy Bypass -File scripts/setup-local-https.ps1",
    "diagnose:meta-oauth": "node scripts/meta-oauth-diagnostic.mjs",
    "build": "vite build",
    "start": "bun run serve.ts",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "publish": "bash ./publish.sh",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.158.1",
    "@tanstack/react-start": "^1.158.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.20.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.5",
    "wrangler": "^4.111.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.25.12": true,
    "sharp@0.34.5": true,
    "workerd@1.20260710.1": true
  }
}
